{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "admin/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    { "src": "/admin/(.*)", "dest": "/admin/dist/$1" },
    { "src": "/admin", "dest": "/admin/dist/index.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
